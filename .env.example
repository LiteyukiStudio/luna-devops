# Base environment. Keep this file tiny because config loading uses APP_ENV
# to decide whether `.env.development` or `.env.production` should be read.
APP_ENV=development

# Metrics default to disabled. When explicitly enabled, API uses :9090,
# worker uses :9091, and both use /metrics unless overridden.
# METRICS_ENABLED=false
# METRICS_ADDR=
# METRICS_PATH=/metrics

# Copy the scoped examples for actual local use:
#   cp .env.development.example .env.development
#   cp .env.worker.example .env.worker
