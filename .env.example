# Luna DevOps uses this single file for local development and Docker Compose
# interpolation. Copy it to `.env`; process environment variables still take
# precedence. Set ENV_FILE only when you intentionally want another file.
APP_ENV=development
API_ADDR=:8080
LOG_LEVEL=debug
SECRET_ENCRYPTION_KEY=
DATABASE_URL=postgres://devops:devops@localhost:5432/devops?sslmode=disable
REDIS_ADDR=redis://localhost:6379/0
PUBLIC_BASE_URL=http://localhost:5173
APP_CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Metrics are disabled unless explicitly enabled. Leave METRICS_ADDR empty to
# use the process default: API :9090 and Worker :9091.
METRICS_ENABLED=false
METRICS_ADDR=
METRICS_PATH=/metrics

# Database pool and startup retry settings shared by API and Worker.
DB_MAX_OPEN_CONNS=20
DB_MAX_IDLE_CONNS=5
DB_CONN_MAX_LIFETIME=30m
DB_CONN_MAX_IDLE_TIME=5m
DB_CONNECT_RETRY_ATTEMPTS=12
DB_CONNECT_RETRY_INTERVAL=5s

# Build and deployment defaults. Build jobs run in the Kubernetes cluster
# selected by the deployment target.
BUILD_EXECUTOR_IMAGE=moby/buildkit:v0.24.0-rootless
BUILD_EGRESS_MODE=permissive
BUILD_JOB_TIMEOUT_SECONDS=1800
BUILD_JOB_TTL_SECONDS=3600
BUILD_CACHE_ENABLED=false
BUILD_CACHE_TAG=buildcache
BUILD_NPM_REGISTRY=
BUILD_PRIVATE_EGRESS_CIDRS=
BUILD_PRIVATE_EGRESS_PORTS=443
BUILD_BLOCKED_EGRESS_CIDRS=
DEPLOY_ROLLOUT_TIMEOUT_SECONDS=600
CERT_MANAGER_CLUSTER_ISSUER=letsencrypt-http01

# Trust forwarded client IP headers only from these reverse proxy networks.
# Leave empty when the API is directly exposed.
TRUSTED_PROXY_CIDRS=

# Frontend build-time links.
# VITE_DOCS_BASE_URL=https://luna-devops.liteyuki.org

# Production Compose reads these values from the same `.env` file. Replace all
# placeholders before `docker compose up`; the Compose services themselves set
# APP_ENV=production and container-internal database/Redis addresses.
BOOTSTRAP_TOKEN=replace-with-a-strong-one-time-token
REDIS_PASSWORD=replace-with-a-url-safe-random-password
# For production, replace the empty development value above with a stable key:
# SECRET_ENCRYPTION_KEY=replace-with-64-hex-characters
