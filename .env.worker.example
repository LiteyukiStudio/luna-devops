# Worker container scope. Values here are interpreted from inside the Compose
# network, so use service names instead of host localhost addresses.
APP_ENV=development
LOG_LEVEL=debug
SECRET_ENCRYPTION_KEY=
DATABASE_URL=postgres://devops:devops@postgres:5432/devops?sslmode=disable
REDIS_ADDR=redis:6379

# Worker metrics example for the Compose network. Keep disabled unless scraping it.
METRICS_ENABLED=false
METRICS_ADDR=:9091
METRICS_PATH=/metrics

# Optional runtime knobs.
DEPLOY_ROLLOUT_TIMEOUT_SECONDS=600
CERT_MANAGER_CLUSTER_ISSUER=letsencrypt-http01

# Build jobs run as Kubernetes Jobs in the deployment cluster selected by the
# deployment target environment.
BUILD_EXECUTOR_IMAGE=moby/buildkit:v0.24.0-rootless
BUILD_JOB_TIMEOUT_SECONDS=5400
BUILD_JOB_TTL_SECONDS=3600
BUILD_CACHE_ENABLED=false
BUILD_CACHE_TAG=buildcache
BUILD_NPM_REGISTRY=
BUILD_PRIVATE_EGRESS_CIDRS=
BUILD_BLOCKED_EGRESS_CIDRS=
