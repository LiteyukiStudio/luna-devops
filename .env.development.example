# Host development scope: processes started directly on the host, such as
# `go run ./cmd/api` or `go run ./cmd/worker`.
APP_ENV=development
API_ADDR=:8080
LOG_LEVEL=debug
SECRET_ENCRYPTION_KEY=
DATABASE_URL=postgres://devops:devops@localhost:5432/devops?sslmode=disable
REDIS_ADDR=localhost:6379

# API metrics example for host development. Keep disabled unless scraping it.
# If you run worker directly on the host with this file, use METRICS_ADDR=:9091.
METRICS_ENABLED=false
METRICS_ADDR=:9090
METRICS_PATH=/metrics

# Build network policy scope: optional CIDR controls for build egress checks.
BUILD_PRIVATE_EGRESS_CIDRS=
BUILD_BLOCKED_EGRESS_CIDRS=

# Browser/frontend scope: public URLs and API CORS origins for host dev.
PUBLIC_BASE_URL=http://localhost:5173
APP_CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
