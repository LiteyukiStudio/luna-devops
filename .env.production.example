# Production Compose settings. Copy to .env and replace every placeholder
# before starting docker-compose.yaml or docker-compose-build.yaml.
APP_ENV=production
LOG_LEVEL=info
SECRET_ENCRYPTION_KEY=replace-with-64-hex-characters
BOOTSTRAP_TOKEN=replace-with-a-strong-one-time-token
REDIS_PASSWORD=replace-with-a-strong-random-password
PUBLIC_BASE_URL=http://localhost:8088
APP_CORS_ORIGINS=http://localhost:8088

# Optional external Redis ACL and database selection.
REDIS_USERNAME=
REDIS_DB=0
