# Runtime scope: host processes started with `go run` or local CLIs.
API_ADDR=:8080
APP_ENV=development
LOG_LEVEL=debug
SECRET_ENCRYPTION_KEY=
DATABASE_URL=postgres://devops:devops@localhost:5432/devops?sslmode=disable
REDIS_ADDR=localhost:6379

# Builder scope: Redis-only agent identity. Execution settings use code defaults.
BUILDER_AGENT_NAME=local-builder
BUILDER_SCOPES=
BUILDER_LABELS=
BUILDER_WORKSPACE_HOST_ROOT=

# Build network policy scope: optional CIDR controls for build egress checks.
BUILD_PRIVATE_EGRESS_CIDRS=
BUILD_BLOCKED_EGRESS_CIDRS=

# Browser/frontend scope: public URLs and API CORS origins.
PUBLIC_BASE_URL=http://localhost:5173
APP_CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
